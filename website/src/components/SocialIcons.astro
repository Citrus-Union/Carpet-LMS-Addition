---
import { Icon } from "astro-icon/components";

const links = [
  [
    "GitHub",
    "https://github.com/Citrus-Union/Carpet-LMS-Addition",
    "simple-icons:github",
  ],
  [
    "Modrinth",
    "https://modrinth.com/mod/carpet-lms-addition",
    "simple-icons:modrinth",
  ],
  [
    "CurseForge",
    "https://www.curseforge.com/minecraft/mc-mods/carpet-lms-addition",
    "simple-icons:curseforge",
  ],
];
---

{
  links.map(([label, href, icon]) => (
    <a href={href} rel="me" class="sl-flex" aria-label={label}>
      <span class="sr-only">{label}</span>
      <Icon name={icon} size="1.25rem" aria-hidden="true" />
    </a>
  ))
}
